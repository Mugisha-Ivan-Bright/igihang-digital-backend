// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AdminLevel {
  PROVINCE
  DISTRICT
  SECTOR
  CELL
  VILLAGE
}

enum UserRole {
  SUPER_ADMIN
  GOVERNOR
  MAYOR
  EXECUTIVE_SEC
  VILLAGE_CHIEF
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
  LOGIN
  APPROVE
  REJECT
  LOGOUT
}

enum NotificationType {
  TASK_ASSIGNED
  EVIDENCE_UPLOADED
  COMMENT_ADDED
  STATUS_CHANGED
  SYSTEM_ALERT
  SECURITY_ALERT
}

model AdminUnit {
  id        Int        @id @default(autoincrement())
  name      String
  level     AdminLevel
  code      String     @unique
  parentId  Int?       @map("parentId")
  parent    AdminUnit? @relation("AdminHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  AdminUnit[] @relation("AdminHierarchy")
  
  users     User[]
  tasks     ImihigoTask[]
  locations Location[]

  createdAt DateTime @default(now()) @map("createdAt")

  @@map("AdminUnit")
}

model User {
  id           Int        @id @default(autoincrement())
  nationalId   String     @unique @map("national_id")
  email        String     @unique
  passwordHash String     @map("password")
  name         String
  role         UserRole
  adminUnitId  Int?       @map("adminUnitId")
  adminUnit    AdminUnit? @relation(fields: [adminUnitId], references: [id])
  
  refreshToken      String?   @map("refresh_token")
  refreshTokenExpires DateTime? @map("refresh_token_expires")
  
  issuedTasks   ImihigoTask[] @relation("IssuerTasks")
  assignedTasks ImihigoTask[] @relation("AssigneeTasks")
  evidence      TaskEvidence[]
  comments      CommentAudit[]
  location      Location[]

  systemLogs    SystemLog[]
  notificationsSent Notification[] @relation("SenderNotifications")
  notificationsReceived Notification[] @relation("RecipientNotifications")

  resetToken        String?   @map("reset_token")
  resetTokenExpires DateTime? @map("reset_token_expires")

  createdAt    DateTime    @default(now()) @map("createdAt")

  @@map("User")
}

model ImihigoTask {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  deadline    DateTime
  
  issuerId    Int        @map("issuerId")
  issuer      User       @relation("IssuerTasks", fields: [issuerId], references: [id])
  assigneeId  Int        @map("assigneeId")
  assignee    User       @relation("AssigneeTasks", fields: [assigneeId], references: [id])
  unitId      Int        @map("unitId")
  unit        AdminUnit  @relation(fields: [unitId], references: [id])
  
  locations   Location[]
  evidence    TaskEvidence[]
  comments    CommentAudit[]
  emailLogs   EmailLog[]

  createdAt   DateTime   @default(now()) @map("createdAt")
  updatedAt   DateTime   @default(now()) @updatedAt @map("updatedAt")

  @@map("ImihigoTask")
}

model Location {
  id          Int        @id @default(autoincrement())
  latitude    Decimal    @db.Decimal(10, 8)
  longitude   Decimal    @db.Decimal(11, 8)
  adminUnitId Int?       @map("adminUnitId")
  adminUnit   AdminUnit? @relation(fields: [adminUnitId], references: [id])
  taskId      Int?       @map("taskId")
  task        ImihigoTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      Int?       @map("userId")
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Location")
}

model TaskEvidence {
  id           Int        @id @default(autoincrement())
  fileUrl      String     @map("fileUrl")
  evidenceType String?    @map("evidenceType")
  description  String?
  taskId       Int        @map("taskId")
  task         ImihigoTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById Int?       @map("uploadedById")
  uploadedBy   User?      @relation(fields: [uploadedById], references: [id])
  
  createdAt    DateTime   @default(now()) @map("createdAt")

  @@map("TaskEvidence")
}

model CommentAudit {
  id        Int        @id @default(autoincrement())
  content   String
  taskId    Int?       @map("taskId")
  task      ImihigoTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  Int?       @map("authorId")
  author    User?      @relation(fields: [authorId], references: [id])
  
  createdAt DateTime   @default(now()) @map("createdAt")

  @@map("CommentAudit")
}

model SystemLog {
  id        Int        @id @default(autoincrement())
  userId    Int        @map("userId")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    ActionType
  tableName String     @db.VarChar(50)
  recordId  Int
  oldValue  Json?
  newValue  Json?
  ipAddress String?    @db.VarChar(45)
  createdAt DateTime   @default(now()) @map("createdAt")

  @@index([userId])
  @@index([tableName, recordId])
  @@map("SystemLog")
}

model EmailLog {
  id             Int          @id @default(autoincrement())
  recipientEmail String       @db.VarChar(255)
  subject        String       @db.Text
  templateName   String?      @db.VarChar(100)
  status         String?      @db.VarChar(20)
  errorMessage   String?      @db.Text
  sentAt         DateTime     @default(now()) @map("sentAt")
  taskId         Int?         @map("taskId")
  task           ImihigoTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("EmailLog")
}

model Notification {
  id          Int              @id @default(autoincrement())
  recipientId Int              @map("recipientId")
  recipient   User             @relation("RecipientNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  senderId    Int?             @map("senderId")
  sender      User?            @relation("SenderNotifications", fields: [senderId], references: [id], onDelete: SetNull)
  type        NotificationType
  title       String           @db.VarChar(255)
  message     String           @db.Text
  icon        String?          @db.VarChar(50)
  linkId      Int?
  linkTable   String?          @db.VarChar(50)
  isRead      Boolean          @default(false)
  readAt      DateTime?
  createdAt   DateTime         @default(now()) @map("createdAt")

  @@index([recipientId])
  @@index([senderId])
  @@map("Notification")
}