// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AdminLevel {
  PROVINCE
  DISTRICT
  SECTOR
  CELL
  VILLAGE
}

enum UserRole {
  SUPER_ADMIN
  GOVERNOR
  MAYOR
  EXECUTIVE_SEC
  VILLAGE_CHIEF
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

model AdminUnit {
  id        Int        @id @default(autoincrement())
  name      String
  level     AdminLevel
  code      String     @unique
  parentId  Int?       @map("parentId")
  parent    AdminUnit? @relation("AdminHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  AdminUnit[] @relation("AdminHierarchy")
  
  users     User[]
  tasks     ImihigoTask[]
  locations Location[]

  createdAt DateTime @default(now()) @map("createdAt")

  @@map("AdminUnit")
}

model User {
  id           Int        @id @default(autoincrement())
  nationalId   String     @unique @map("national_id")
  email        String     @unique
  passwordHash String     @map("password")
  name         String
  role         UserRole
  adminUnitId  Int?       @map("adminUnitId")
  adminUnit    AdminUnit? @relation(fields: [adminUnitId], references: [id])
  
  issuedTasks   ImihigoTask[] @relation("IssuerTasks")
  assignedTasks ImihigoTask[] @relation("AssigneeTasks")
  evidence      TaskEvidence[]
  comments      CommentAudit[]
  location      Location[]

  createdAt    DateTime    @default(now()) @map("createdAt")

  @@map("User")
}

model ImihigoTask {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  deadline    DateTime
  
  issuerId    Int        @map("issuerId")
  issuer      User       @relation("IssuerTasks", fields: [issuerId], references: [id])
  assigneeId  Int        @map("assigneeId")
  assignee    User       @relation("AssigneeTasks", fields: [assigneeId], references: [id])
  unitId      Int        @map("unitId")
  unit        AdminUnit  @relation(fields: [unitId], references: [id])
  
  locations   Location[]
  evidence    TaskEvidence[]
  comments    CommentAudit[]

  createdAt   DateTime   @default(now()) @map("createdAt")
  updatedAt   DateTime   @default(now()) @updatedAt @map("updatedAt")

  @@map("ImihigoTask")
}

model Location {
  id          Int        @id @default(autoincrement())
  latitude    Decimal    @db.Decimal(10, 8)
  longitude   Decimal    @db.Decimal(11, 8)
  adminUnitId Int?       @map("adminUnitId")
  adminUnit   AdminUnit? @relation(fields: [adminUnitId], references: [id])
  taskId      Int?       @map("taskId")
  task        ImihigoTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      Int?       @map("userId")
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Location")
}

model TaskEvidence {
  id           Int        @id @default(autoincrement())
  fileUrl      String     @map("fileUrl")
  evidenceType String?    @map("evidenceType")
  description  String?
  taskId       Int        @map("taskId")
  task         ImihigoTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById Int?       @map("uploadedById")
  uploadedBy   User?      @relation(fields: [uploadedById], references: [id])
  
  createdAt    DateTime   @default(now()) @map("createdAt")

  @@map("TaskEvidence")
}

model CommentAudit {
  id        Int        @id @default(autoincrement())
  content   String
  taskId    Int?       @map("taskId")
  task      ImihigoTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  Int?       @map("authorId")
  author    User?      @relation(fields: [authorId], references: [id])
  
  createdAt DateTime   @default(now()) @map("createdAt")

  @@map("CommentAudit")
}