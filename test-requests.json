{
    "auth": {
        "register": {
            "super_admin": {
                "url": "{{host}}/auth/register",
                "method": "POST",
                "body": {
                    "email": "admin@gov.rw",
                    "password": "Password123!",
                    "name": "Super Admin",
                    "nationalId": "1111222233334444",
                    "role": "SUPER_ADMIN",
                    "adminUnitId": 1
                }
            },
            "governor": {
                "url": "{{host}}/auth/register",
                "method": "POST",
                "body": {
                    "email": "governor@gov.rw",
                    "password": "Password123!",
                    "name": "Governor Paul",
                    "nationalId": "1111222233335555",
                    "role": "GOVERNOR",
                    "adminUnitId": 1,
                    "latitude": -1.9441,
                    "longitude": 30.0619
                }
            },
            "mayor": {
                "url": "{{host}}/auth/register",
                "method": "POST",
                "body": {
                    "email": "mayor.test@gov.rw",
                    "password": "Password123!",
                    "name": "Mayor Jean",
                    "nationalId": "1234567890123456",
                    "role": "MAYOR",
                    "adminUnitId": 6,
                    "latitude": -1.9441,
                    "longitude": 30.0619
                }
            }
        },
        "login": {
            "url": "{{host}}/auth/login",
            "method": "POST",
            "body": {
                "email": "admin@gov.rw",
                "password": "Password123!"
            }
        },
        "logout": {
            "url": "{{host}}/auth/logout",
            "method": "POST",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "refresh_token": {
            "url": "{{host}}/auth/refresh",
            "method": "POST",
            "note": "Sends the refresh_token cookie automatically if using a client that supports cookies."
        },
        "get_all_users": {
            "url": "{{host}}/auth/users",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "get_user_by_id": {
            "url": "{{host}}/auth/users/1",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "update_user": {
            "url": "{{host}}/auth/users/1",
            "method": "PATCH",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            },
            "body": {
                "name": "Updated Name",
                "adminUnitId": 2
            }
        },
        "delete_user": {
            "url": "{{host}}/auth/users/2",
            "method": "DELETE",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "forgot_password": {
            "url": "{{host}}/auth/forgot-password",
            "method": "POST",
            "body": {
                "email": "admin@gov.rw"
            }
        },
        "reset_password": {
            "url": "{{host}}/auth/reset-password",
            "method": "POST",
            "body": {
                "token": "ACTUAL_TOKEN_FROM_EMAIL",
                "newPassword": "NewSecurePassword123!"
            }
        }
    },
    "notifications": {
        "my_notifications": {
            "url": "{{host}}/notifications",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "all_notifications": {
            "url": "{{host}}/notifications/all",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "mark_as_read": {
            "url": "{{host}}/notifications/1/read",
            "method": "PATCH",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "mark_all_read": {
            "url": "{{host}}/notifications/read-all",
            "method": "PATCH",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        }
    },
    "dashboard": {
        "health": {
            "url": "{{host}}/dashboard/health",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "stats": {
            "url": "{{host}}/dashboard/stats",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "active_users": {   
            "url": "{{host}}/dashboard/active-users",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        }
    },
    "admin_units": {
        "all": {
            "url": "{{host}}/admin-units",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "by_level": {
            "url": "{{host}}/admin-units?level=DISTRICT",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "unallocated": {
            "url": "{{host}}/admin-units/unallocated",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        }
    },
    "task_mgmt": {
        "all_tasks": {
            "url": "{{host}}/mgmt/tasks",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "all_evidence": {
            "url": "{{host}}/mgmt/tasks/evidence",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "all_comments": {
            "url": "{{host}}/mgmt/tasks/comments",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        }
    },
    "logs": {
        "system": {
            "url": "{{host}}/logs",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "emails": {
            "url": "{{host}}/mail/logs",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        }
    },
    "mail": {
        "send": {
            "url": "{{host}}/mail/send",
            "method": "POST",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            },
            "body": {
                "to": "recipient@example.com",
                "subject": "Test Email",
                "body": "Hello from Igihango!"
            }
        }
    },
    "geospatial": {
        "all_locations": {
            "url": "{{host}}/mgmt/locations",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        }
    },
    "variables": {
        "host": "http://localhost:3001",
        "notes": "Replace {{jwt_token}} with a token from the login response. Cookies (access_token, refresh_token) are set automatically on login."
    }
}