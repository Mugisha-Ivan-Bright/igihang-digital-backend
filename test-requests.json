{
    "auth": {
        "register": {
            "super_admin": {
                "url": "{{host}}/auth/register",
                "method": "POST",
                "body": {
                    "email": "admin@gov.rw",
                    "password": "Password123!",
                    "name": "Super Admin",
                    "nationalId": "1111222233334444",
                    "role": "SUPER_ADMIN",
                    "adminUnitId": 1
                }
            },
            "governor": {
                "url": "{{host}}/auth/register",
                "method": "POST",
                "body": {
                    "email": "governor@gov.rw",
                    "password": "Password123!",
                    "name": "Governor Paul",
                    "nationalId": "1111222233335555",
                    "role": "GOVERNOR",
                    "adminUnitId": 1,
                    "latitude": -1.9441,
                    "longitude": 30.0619
                }
            },
            "mayor": {
                "url": "{{host}}/auth/register",
                "method": "POST",
                "body": {
                    "email": "mayor.test@gov.rw",
                    "password": "Password123!",
                    "name": "Mayor Jean",
                    "nationalId": "1234567890123456",
                    "role": "MAYOR",
                    "adminUnitId": 6,
                    "latitude": -1.9441,
                    "longitude": 30.0619
                }
            }
        },
        "login": {
            "url": "{{host}}/auth/login",
            "method": "POST",
            "body": {
                "email": "admin@gov.rw",
                "password": "Password123!"
            }
        },
        "logout": {
            "url": "{{host}}/auth/logout",
            "method": "POST",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "refresh_token": {
            "url": "{{host}}/auth/refresh",
            "method": "POST",
            "note": "Sends the refresh_token cookie automatically if using a client that supports cookies."
        },
        "get_all_users": {
            "url": "{{host}}/auth/users",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "get_user_by_id": {
            "url": "{{host}}/auth/users/1",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "update_user": {
            "url": "{{host}}/auth/users/1",
            "method": "PATCH",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            },
            "body": {
                "name": "Updated Name",
                "adminUnitId": 2
            }
        },
        "delete_user": {
            "url": "{{host}}/auth/users/2",
            "method": "DELETE",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "forgot_password": {
            "url": "{{host}}/auth/forgot-password",
            "method": "POST",
            "body": {
                "email": "admin@gov.rw"
            }
        },
        "reset_password": {
            "url": "{{host}}/auth/reset-password",
            "method": "POST",
            "body": {
                "token": "ACTUAL_TOKEN_FROM_EMAIL",
                "newPassword": "NewSecurePassword123!"
            }
        }
    },
    "notifications": {
        "my_notifications": {
            "url": "{{host}}/notifications",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "all_notifications": {
            "url": "{{host}}/notifications/all",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "mark_as_read": {
            "url": "{{host}}/notifications/1/read",
            "method": "PATCH",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "mark_all_read": {
            "url": "{{host}}/notifications/read-all",
            "method": "PATCH",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        }
    },
    "dashboard": {
        "health": {
            "url": "{{host}}/dashboard/health",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "stats": {
            "url": "{{host}}/dashboard/stats",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "active_users": {
            "url": "{{host}}/dashboard/active-users",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        }
    },
    "admin_units": {
        "all": {
            "url": "{{host}}/admin-units",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "by_level": {
            "url": "{{host}}/admin-units?level=DISTRICT",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "unallocated": {
            "url": "{{host}}/admin-units/unallocated",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        }
    },
    "task_mgmt": {
        "all_tasks": {
            "url": "{{host}}/mgmt/tasks",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "all_evidence": {
            "url": "{{host}}/mgmt/tasks/evidence",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "all_comments": {
            "url": "{{host}}/mgmt/tasks/comments",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        }
    },
    "task_scheduler": {
        "note": "Task scheduler endpoints for automated deadline monitoring. Requires SUPER_ADMIN role.",
        "check_overdue": {
            "url": "{{host}}/tasks/scheduler/check-overdue",
            "method": "POST",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            },
            "description": "Manually trigger overdue tasks check. Updates task status to OVERDUE if deadline has passed and sends notifications."
        },
        "send_reminders": {
            "url": "{{host}}/tasks/scheduler/send-reminders",
            "method": "POST",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            },
            "description": "Manually trigger deadline reminders. Sends notifications for tasks due within 3 days."
        },
        "automated_schedules": {
            "overdue_check": "Runs automatically every day at midnight (00:00)",
            "deadline_reminders": "Runs automatically every day at 9:00 AM"
        }
    },
    "logs": {
        "system": {
            "url": "{{host}}/logs",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "emails": {
            "url": "{{host}}/mail/logs",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        }
    },
    "mail": {
        "send": {
            "url": "{{host}}/mail/send",
            "method": "POST",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            },
            "body": {
                "to": "recipient@example.com",
                "subject": "Test Email",
                "body": "Hello from Igihango!"
            }
        }
    },
    "geospatial": {
        "all_locations": {
            "url": "{{host}}/mgmt/locations",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        }
    },
    "leader": {
        "note": "All /leader routes require a logged-in leader (GOVERNOR, MAYOR, EXECUTIVE_SEC, or VILLAGE_CHIEF).",
        "subordinates": {
            "url": "{{host}}/leader/subordinates",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "superiors": {
            "url": "{{host}}/leader/superiors",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "my_tasks": {
            "url": "{{host}}/leader/tasks/mine",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "unit_tasks": {
            "url": "{{host}}/leader/tasks/unit",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "unit_tasks_by_status": {
            "url": "{{host}}/leader/tasks/unit?status=IN_PROGRESS",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "assign_task": {
            "url": "{{host}}/leader/tasks",
            "method": "POST",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            },
            "body": {
                "title": "Construct community hall",
                "description": "Build a new community hall in Sector X",
                "assigneeId": 2,
                "unitId": 3,
                "deadline": "2026-06-30T00:00:00Z"
            }
        },
        "update_task_status": {
            "url": "{{host}}/leader/tasks/1/status",
            "method": "PATCH",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            },
            "body": {
                "status": "IN_PROGRESS"
            }
        },
        "add_evidence": {
            "url": "{{host}}/leader/tasks/1/evidence",
            "method": "POST",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            },
            "body": {
                "fileUrl": "https://storage.example.com/evidence/photo1.jpg",
                "evidenceType": "PHOTO",
                "description": "Foundation laid — 40% complete"
            },
            "note": "Use this endpoint if you already have a Cloudinary URL"
        },
        "upload_evidence": {
            "url": "{{host}}/leader/tasks/1/evidence/upload",
            "method": "POST",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}",
                "Content-Type": "multipart/form-data"
            },
            "body": "FormData with 'file' and optional 'description'",
            "note": "Upload file directly. Backend will upload to Cloudinary and store the URL. Max 50MB."
        },
        "get_evidence": {
            "url": "{{host}}/leader/tasks/1/evidence",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "add_comment": {
            "url": "{{host}}/leader/tasks/1/comments",
            "method": "POST",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            },
            "body": {
                "content": "Please upload updated site photos by Friday."
            }
        },
        "get_comments": {
            "url": "{{host}}/leader/tasks/1/comments",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "my_progress": {
            "url": "{{host}}/leader/progress",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "progress_cross_scope": {
            "url": "{{host}}/leader/progress/1",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            },
            "note": "Replace /1 with any adminUnitId to view progress for a different unit."
        }
    },
    "variables": {
        "host": "http://localhost:3001",
        "notes": "Replace {{jwt_token}} with a token from the login response. Cookies (access_token, refresh_token) are set automatically on login."
    }
}