{
    "auth": {
        "register": {
            "super_admin": {
                "url": "{{host}}/auth/register",
                "method": "POST",
                "body": {
                    "email": "admin@gov.rw",
                    "password": "Password123!",
                    "name": "Super Admin",
                    "nationalId": "1111222233334444",
                    "role": "SUPER_ADMIN",
                    "adminUnitId": 1
                }
            },
            "mayor": {
                "url": "{{host}}/auth/register",
                "method": "POST",
                "body": {
                    "email": "mayor.test@gov.rw",
                    "password": "Password123!",
                    "name": "Mayor Jean",
                    "nationalId": "1234567890123456",
                    "role": "MAYOR",
                    "adminUnitId": 6,
                    "latitude": -1.9441,
                    "longitude": 30.0619
                }
            },
            "executive_sec": {
                "url": "{{host}}/auth/register",
                "method": "POST",
                "body": {
                    "email": "exec.test@gov.rw",
                    "password": "Password123!",
                    "name": "Exec Sec Paul",
                    "nationalId": "1234567890654321",
                    "role": "EXECUTIVE_SEC",
                    "adminUnitId": 9
                }
            }
        },
        "login": {
            "url": "{{host}}/auth/login",
            "method": "POST",
            "body": {
                "email": "mayor.test@gov.rw",
                "password": "Password123!"
            }
        },
        "get_all_users": {
            "description": "Requires SUPER_ADMIN or GOVERNOR role",
            "url": "{{host}}/auth/users",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "get_user_by_id": {
            "description": "Requires valid JWT token",
            "url": "{{host}}/auth/users/{{user_id}}",
            "method": "GET",
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        },
        "delete_user": {
            "description": "Requires SUPER_ADMIN role",
            "url": "{{host}}/auth/users/{{user_id}}",
            "method": "DELETE",     
            "headers": {
                "Authorization": "Bearer {{jwt_token}}"
            }
        }
    },
    "variables": {
        "host": "http://localhost:3001",    
        "notes": "Note: user_id is now an INTEGER. Replace {{jwt_token}} and {{user_id}} with actual values."
    }
}